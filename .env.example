# =====================================
# Telegram Bot
# =====================================
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# =====================================
# Server
# =====================================
HOST=0.0.0.0
PORT=8000

# =====================================
# Application
# =====================================
DEBUG=False
MAX_VIDEO_SIZE_MB=200
TEMP_DIR=temp
OUTPUT_DIR=output

# =====================================
# Translation
# (লোকাল মডেল ব্যবহার করলে খালি রাখতে পারেন)
# =====================================
GEMINI_API_KEY=
OPENAI_API_KEY=

# =====================================
# FFmpeg
# =====================================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# =====================================
# Whisper
# tiny | base | small | medium | large-v3
# =====================================
WHISPER_MODEL=base

# =====================================
# Speaker Diarization
# (Hugging Face Token)
# =====================================
HF_TOKEN=

# =====================================
# Queue
# =====================================
REDIS_URL=redis://localhost:6379/0

# =====================================
# Database
# =====================================
DATABASE_URL=sqlite:///database.db

# =====================================
# Render
# =====================================
RENDER=False
